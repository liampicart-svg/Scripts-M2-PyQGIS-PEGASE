# -*- coding: utf-8 -*-
import os
import re
import processing
from datetime import datetime
from qgis.core import (QgsProject, QgsVectorLayer, QgsMapLayer, 
                       QgsRasterLayer, QgsVectorFileWriter)
from qgis.analysis import QgsZonalStatistics
from qgis.PyQt.QtWidgets import QMessageBox

#%% configuration
# appel du maillage vectoriel genere dans qgis
nom_couche_maillage = "4 - Maillage pour l'analyse des saisons (zone Sud)"
# ciblage du dossier contenant les mnt topographiques et bathymetriques
nom_du_groupe_rasters = "Bathymétries sans masque" 
# parametres de sortie du tableau de donnees final
dossier_resultat = r"C:\Liam\QGIS\PEGASE_Projet_Liam\Comparaison\Saison\Excel_maillage_cube"
nom_fichier_csv = "VARIATIONS_ELEVATION_MAILLAGE-MATRICE_COMPLETE_Zone_Sud_c0.csv"

# filtre des annees d etude pour ecarter les leves hors sujet
dates_valides = [2014, 2015, 2020, 2021, 2022, 2024, 2025, 2026]

#%% fonctions outils pour le decodage et le formatage
def extract_date_robust(name):
    # nettoie les separateurs du nom de fichier pour isoler les chiffres
    cleaned = name.replace('_', '/').replace('-', '/').replace('.', '/')
    parts = re.findall(r'\d+', cleaned)
    
    dt = None
    if len(parts) >= 3:
        # decode le format standard aaaa/mm/jj
        if int(parts[0]) > 2000: 
            dt = datetime(int(parts[0]), int(parts[1]), int(parts[2]))
        # decode le format inverse jj/mm/aaaa
        else: 
            dt = datetime(int(parts[2]), int(parts[1]), int(parts[0]))
    elif len(parts) == 1 and len(parts[0]) == 4:
        # si seul l annee est trouvee, fige la date au 1er janvier
        dt = datetime(int(parts[0]), 1, 1)
        
    return dt

def formater_date_csv(dt, name):
    # convertit l objet date en chaine normalisee pour le csv final
    return dt.strftime('%d/%m/%Y') if dt else name

#%% initialisation du projet et correction des geometries
def run_traitement_complet():
    print("--- DÉMARRAGE DU TRAITEMENT (CORRECTIF 2014-2015) ---")
    if not os.path.exists(dossier_resultat): os.makedirs(dossier_resultat)

    # chargement du maillage de base
    layers_m = QgsProject.instance().mapLayersByName(nom_couche_maillage)
    if not layers_m:
        QMessageBox.critical(None, "Erreur", f"Couche '{nom_couche_maillage}' introuvable.")
        return
    
    # reparation des polygones (supprime les mailles invalides ou superposees)
    layer_maille = processing.run("native:fixgeometries", {'INPUT': layers_m[0], 'OUTPUT': 'memory:'})['OUTPUT']

    # acces au groupe de rasters cibles
    root = QgsProject.instance().layerTreeRoot()
    groupe_r = root.findGroup(nom_du_groupe_rasters)
    if not groupe_r:
        QMessageBox.critical(None, "Erreur", f"Groupe '{nom_du_groupe_rasters}' non trouvé.")
        return

#%% recuperation, filtrage et tri chronologique des rasters
    layers_raw = [l.layer() for l in groupe_r.children() if l.layer().type() == QgsMapLayer.RasterLayer]
    layers_dt = []
    
    for lyr in layers_raw:
        dt = extract_date_robust(lyr.name())
        # validation de l annee par rapport a la liste de configuration
        if dt and dt.year in dates_valides:
            layers_dt.append((dt, lyr))
            print(f"ACCEPTÉ : {lyr.name()} (Année reconnue : {dt.year})")
        else:
            annee_trouvee = dt.year if dt else "Inconnue"
            print(f"REJETÉ : {lyr.name()} (Année détectée : {annee_trouvee})")

    # tri chronologique indispensable pour que les soustractions a-b soient toujours correctes
    layers_dt.sort(key=lambda x: x[0])
    print(f"\nTOTAL : {len(layers_dt)} rasters prêts pour le calcul.\n")

#%% boucles de croisement et calculs des matrices dOD
    liste_en_tetes_vs = []
    idx = 1
    total_comparaisons = sum(range(len(layers_dt)))

    for i in range(len(layers_dt)):
        for j in range(i + 1, len(layers_dt)):
            dt_a, l_a = layers_dt[i]
            dt_r, l_r = layers_dt[j]
            
            # astuce : qgis bloque les noms de colonnes longs. on cree un identifiant court 'DIFF_X'
            col_id = f"DIFF_{idx}" 
            # on stocke le vrai nom long (ex: 25/06/2024 vs 30/06/2025) dans une liste pour plus tard
            nom_long_vs = f"{formater_date_csv(dt_a, l_a.name())} vs {formater_date_csv(dt_r, l_r.name())}"
            liste_en_tetes_vs.append(nom_long_vs)
            
            print(f"[{idx}/{total_comparaisons}] Calcul : {nom_long_vs}")

            # calcul differentiel : raster recent - raster ancien
            formula = f"\"{l_r.name()}@1\" - \"{l_a.name()}@1\""
            
            res_calc = processing.run("qgis:rastercalculator", {
                'EXPRESSION': formula, 
                'LAYERS': [l_r, l_a],
                'CELLSIZE': 0, 
                'EXTENT': layer_maille.extent(), 
                'CRS': layer_maille.crs(),
                'OUTPUT': 'TEMPORARY_OUTPUT'
            })
            
            # analyse zonale : calcul de la variation moyenne par carre de maille
            lyr_dod = QgsRasterLayer(res_calc['OUTPUT'], "temp", "gdal")
            zonal_stats = QgsZonalStatistics(layer_maille, lyr_dod, f"{col_id}_", 1, QgsZonalStatistics.Mean)
            zonal_stats.calculateStatistics(None)
            
            # nettoyage du nom de la colonne : on passe de 'DIFF_X_mean' a 'DIFF_X'
            idx_champ = layer_maille.fields().indexFromName(f"{col_id}_mean")
            layer_maille.startEditing()
            layer_maille.renameAttribute(idx_champ, col_id)
            layer_maille.commitChanges()
            idx += 1

#%% export csv et re-injection des noms de colonnes longs
    chemin_csv = os.path.join(dossier_resultat, nom_fichier_csv)
    options = QgsVectorFileWriter.SaveVectorOptions()
    options.driverName = "CSV"
    options.layerOptions = ['GEOMETRY=AS_WKT', 'SEPARATOR=SEMICOLON']
    
    QgsVectorFileWriter.writeAsVectorFormatV2(layer_maille, chemin_csv, QgsProject.instance().transformContext(), options)

    # post-traitement du fichier texte pour remplacer les 'DIFF_X' temporaires par les vrais noms longs
    if os.path.exists(chemin_csv):
        with open(chemin_csv, 'r', encoding='utf-8-sig') as f:
            lignes = f.readlines()
        
        colonnes_brutes = lignes[0].split(';')
        nouvel_en_tete = []
        map_idx = 0
        for col in colonnes_brutes:
            c = col.strip().replace('"', '')
            if "DIFF_" in c:
                # substitution de l id court par le nom de la periode stockee
                nouvel_en_tete.append(f'"{liste_en_tetes_vs[map_idx]}"')
                map_idx += 1
            elif c.lower() in ["wkt_geom", "geometry"]:
                # normalisation de la colonne geometrique en 'WKT' pour python
                nouvel_en_tete.append('"WKT"')
            else:
                nouvel_en_tete.append(col.strip())
        
        # reecriture propre du csv final pret pour pandas
        lignes[0] = ';'.join(nouvel_en_tete) + '\n'
        with open(chemin_csv, 'w', encoding='utf-8-sig') as f:
            f.writelines(lignes)
            
        QMessageBox.information(None, "Terminé", "Matrice 2014-2026 générée avec succès !")

# lancement de la macro de calcul dans qgis
run_traitement_complet()
